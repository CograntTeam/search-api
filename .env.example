# =============================================================================
# Cogrant Search API — environment variables
# =============================================================================
# Copy to .env and fill in. Never commit .env.
#
# On Render, set each of these in the service's Environment tab.

# --- Runtime --------------------------------------------------------------
ENV=development                 # development | staging | production
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
PORT=8000                       # Render injects this automatically in prod

# --- Public URL ----------------------------------------------------------
# Used when passing a callback URL to n8n so it knows where to POST results.
API_BASE_URL=http://localhost:8000   # prod: https://api.cogrant.eu

# --- Airtable (see AIRTABLE_SCHEMA.md) ----------------------------------
# Create a Personal Access Token at https://airtable.com/create/tokens with:
#   scopes: schema.bases:read, data.records:read, data.records:write
#   access: the Cogrant base (apphC0wbp5dYfACfb)
AIRTABLE_PAT=patXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=apphC0wbp5dYfACfb
AIRTABLE_API_KEYS_TABLE_ID=tblfXzQKso559HNlQ
AIRTABLE_API_JOBS_TABLE_ID=tbl5QazdvtAVbAHZO
AIRTABLE_SEARCH_MATCHES_TABLE_ID=tblLPLC7MfX7nuxyr

# --- n8n -----------------------------------------------------------------
# Base URL of your n8n Cloud webhooks (no trailing slash).
# e.g. https://<instance>.app.n8n.cloud/webhook
N8N_WEBHOOK_BASE_URL=https://<instance>.app.n8n.cloud/webhook

# Webhook path for the stage-1 search workflow.
# The API calls: {N8N_WEBHOOK_BASE_URL}/{N8N_SEARCH_PATH}
# (1.1A / 1.1B are internal sub-workflows of 1.0, not webhooks.)
N8N_SEARCH_PATH=search-initiation

# --- Internal shared secret ---------------------------------------------
# Used to authenticate n8n's callback to POST /internal/jobs/{id}/complete.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_SHARED_SECRET=replace-me-with-a-long-random-string
